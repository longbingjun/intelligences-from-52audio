---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/paths";
import fs from "node:fs";
import path from "node:path";

export function getStaticPaths() {
  const reportsDir = path.join(process.cwd(), "..", "data", "reports");
  if (!fs.existsSync(reportsDir)) return [];
  return fs
    .readdirSync(reportsDir)
    .filter((f) => f.endsWith(".json"))
    .map((file) => {
      const report = JSON.parse(fs.readFileSync(path.join(reportsDir, file), "utf-8"));
      return { params: { id: report.id }, props: { report } };
    });
}

const { report } = Astro.props;
const v = report.views || {};
const cost = v.cost || {};
const bom = (cost.bom_table || []).filter(
  (r: { model?: string }) => (r.model || "").trim()
);

const market = v.market || {};
type SellingPoint = { text?: string; tag?: string; tags?: string[]; evidence?: { confidence?: number } };
const sellingPoints = ((market.selling_points || []) as SellingPoint[]).filter((sp) => (sp.text || "").trim());
const scenarios = (market.scenarios || []) as string[];
const positioningSummary = (market.positioning_summary || "").trim();
const hasMarket = sellingPoints.length > 0 || scenarios.length > 0 || !!positioningSummary;
---

<BaseLayout title={`${report.brand} ${report.model} 拆解`} activeNav="category">
  <p class="text-sm">
    <a href={withBase(`/category/${encodeURIComponent(report.category || "")}`)} class="text-[var(--muted)]">
      ← 返回 {report.category || "品类对比"}
    </a>
  </p>
  <div class="rounded-2xl border border-[var(--line)] bg-white p-6 shadow-sm">
    <h1 class="text-2xl font-bold">{report.brand} {report.model}</h1>
    <p class="text-sm text-[var(--muted)]">
      发布 {report.published_at} · 作者 {report.author || "未知"}
    </p>
    <p class="mt-3">{report.summary}</p>
    <p class="mt-4">
      <a href={report.url} target="_blank" rel="noopener" class="font-medium">
        查看 52audio 原文 →
      </a>
    </p>
  </div>

  {
    hasMarket && (
      <>
        <h2 class="mt-8 text-lg font-bold">定位与卖点</h2>
        <div class="rounded-2xl border border-[var(--line)] bg-white p-6 shadow-sm">
          {positioningSummary && (
            <p class="m-0 text-sm leading-relaxed text-[var(--text)]">{positioningSummary}</p>
          )}
          {scenarios.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {scenarios.map((s) => (
                <span class="rounded-full bg-[#f3f4f8] px-2.5 py-1 text-xs text-[var(--muted)]">{s}</span>
              ))}
            </div>
          )}
          {sellingPoints.length > 0 && (
            <ul class="mt-4 m-0 list-none space-y-2 p-0">
              {sellingPoints.map((sp) => (
                <li class="flex gap-2 rounded-xl border border-[var(--line)] bg-[#fafbff] p-3">
                  <div class="flex shrink-0 flex-wrap gap-1 self-start">
                    <span class="inline-block rounded-full bg-[#eef3ff] px-2 py-0.5 text-xs font-semibold text-[var(--primary-dark)]">
                      {sp.tag || "其他"}
                    </span>
                    {(sp.tags || []).map((t) => (
                      <span class="inline-block rounded-full bg-[#f3f4f8] px-2 py-0.5 text-xs text-[var(--muted)]">
                        {t}
                      </span>
                    ))}
                  </div>
                  <p class="m-0 flex-1 text-sm leading-relaxed text-[var(--text)]">{sp.text}</p>
                </li>
              ))}
            </ul>
          )}
        </div>
      </>
    )
  }

  <h2 class="mt-8 text-lg font-bold">BOM 摘要（{bom.length} 项）</h2>
  <div class="overflow-x-auto rounded-xl border border-[var(--line)] bg-white">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-[#f8faff] text-left">
          <th class="px-3 py-2">侧别</th>
          <th class="px-3 py-2">部件</th>
          <th class="px-3 py-2">型号</th>
          <th class="px-3 py-2">角色</th>
        </tr>
      </thead>
      <tbody>
        {
          bom.slice(0, 40).map(
            (r: { side: string; component: string; model: string; role: string }) => (
              <tr class="border-t border-[var(--line)]">
                <td class="px-3 py-2">{r.side}</td>
                <td class="px-3 py-2">{r.component}</td>
                <td class="px-3 py-2">{r.model}</td>
                <td class="px-3 py-2">{r.role}</td>
              </tr>
            )
          )
        }
      </tbody>
    </table>
  </div>
</BaseLayout>
