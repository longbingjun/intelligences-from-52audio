---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/paths";
import { resolveImageSrc } from "../../lib/images";
import {
  collectSellingPointTags,
  computeUnboxModuleMetrics,
  sellingPointTagStyle,
  unboxModuleStyle,
} from "../../lib/unboxingMetrics";
import fs from "node:fs";
import path from "node:path";

export function getStaticPaths() {
  const productsDir = path.join(process.cwd(), "public", "data", "products");
  const files = fs.readdirSync(productsDir).filter((f) => f.endsWith(".json") && f !== "index.json");
  return files.map((file) => {
    const product = JSON.parse(fs.readFileSync(path.join(productsDir, file), "utf-8"));
    return { params: { id: product.canonical_id }, props: { product } };
  });
}

const { product } = Astro.props;
const snap = product.cost_snapshot || {};
const market = product.market || {};
type SellingPoint = { text?: string; tag?: string; tags?: string[]; evidence?: { confidence?: number } };
const sellingPoints = ((market.selling_points || []) as SellingPoint[]).filter((sp) => (sp.text || "").trim());
const scenarios = (market.scenarios || []) as string[];
const positioningSummary = (market.positioning_summary || "").trim();
const hasMarket = sellingPoints.length > 0 || scenarios.length > 0 || !!positioningSummary;
const bom = (product.bom_table || []).filter(
  (r: { model?: string; component?: string }) => (r.model || "").trim() || (r.component || "").trim()
);
const unboxing = product.unboxing || null;

const caseRows = bom.filter((r: { side?: string }) => r.side === "充电盒");
const earRows = bom.filter((r: { side?: string }) => r.side === "耳机");
const otherRows = bom.filter(
  (r: { side?: string }) => r.side !== "充电盒" && r.side !== "耳机"
);

function formatBomRole(role: string): string {
  if (!role?.trim()) return "—";
  if (role === "major") return "核心部件";
  if (role === "minor") return "外围部件";
  return role;
}

function formatCell(val: string | undefined): string {
  const v = (val || "").trim();
  return v || "—";
}

// TWS / 开放式耳机（含耳夹式）需要拆分整机/充电盒/单只耳机重量；
// 头戴式/骨传导/有线/颈挂式等单一整机形态只展示一个总重。
const MULTI_PART_WEIGHT_CATEGORIES = new Set(["真无线耳机TWS", "开放式耳机"]);
const isMultiPartWeight = MULTI_PART_WEIGHT_CATEGORIES.has(product.category);
const weightCards = isMultiPartWeight
  ? [
      ["整机重量", snap.weight_g],
      ["充电盒重量", snap.weight_case_g],
      ["单只耳机重量", snap.weight_earbud_g],
    ]
  : [["重量", snap.weight_g]];

const priceTxt =
  snap.price_cny != null
    ? `¥${snap.price_cny}${snap.price_layer === "channel" ? " (渠道)" : ""}`
    : "待补充";

type UnboxModule = {
  description?: string;
  accessories?: string[];
  appearance_images?: { url: string; caption?: string; alt?: string }[];
};

const unboxSections: { key: "packaging" | "charging_case" | "earbuds"; title: string; mod: UnboxModule | null }[] = [
  { key: "packaging", title: "包装", mod: unboxing?.packaging ?? null },
  { key: "charging_case", title: "充电盒", mod: unboxing?.charging_case ?? null },
  { key: "earbuds", title: "耳机", mod: unboxing?.earbuds ?? null },
];

// 原始图片来自 52audio OSS，开启了 Referer 防盗链，浏览器无法直接热链展示，
// 需要用构建阶段缓存的本地文件；未成功缓存的图跳过渲染，避免出现裂图图标。
type ResolvedImage = { src: string; alt?: string; caption?: string };
function resolveImages(images?: { url: string; alt?: string; caption?: string }[]): ResolvedImage[] {
  return (images || [])
    .map((img) => {
      const src = resolveImageSrc(img.url);
      return src ? { src, alt: img.alt, caption: img.caption } : null;
    })
    .filter((img): img is ResolvedImage => img !== null);
}

const resolvedSummaryImages: ResolvedImage[] = resolveImages(
  (product.summary_image_urls || []) as { url: string; alt?: string; caption?: string }[]
);

const allLightboxImages: ResolvedImage[] = [
  ...resolvedSummaryImages,
  ...unboxSections.flatMap(({ mod }) => (mod ? resolveImages(mod.appearance_images) : [])),
];
const lightboxJson = JSON.stringify(allLightboxImages);
---

<BaseLayout title={`${product.brand} ${product.model}`} activeNav="category">
  <div class="mb-4 text-sm">
    <a href={withBase(`/category/${encodeURIComponent(product.category)}`)} class="text-[var(--muted)]">
      ← 返回 {product.category} 对比
    </a>
  </div>

  <div class="rounded-2xl border border-[var(--line)] bg-white p-6 shadow-sm">
    <span class="rounded-full bg-[#eef3ff] px-2 py-0.5 text-xs font-semibold text-[var(--primary-dark)]">
      {product.category}
    </span>
    <h1 class="mt-2 text-2xl font-bold">{product.brand} {product.model}</h1>
    <p class="text-sm text-[var(--muted)]">
      成本完整度 {Math.round((snap.data_completeness || 0) * 100)}%
      {unboxing?.completeness != null && (
        <> · 开箱图完整度 {Math.round((unboxing.completeness || 0) * 100)}%</>
      )}
      {snap.channel_url && (
        <>
          {" "}
          · <a href={snap.channel_url} target="_blank" rel="noopener">渠道页</a>
        </>
      )}
    </p>
  </div>

  {
    hasMarket && (
      <section class="mt-8 rounded-2xl border border-[var(--line)] bg-white p-6 shadow-sm">
        <h2 class="m-0 text-lg font-bold">定位与卖点</h2>
        {positioningSummary && (
          <p class="mt-3 text-sm leading-relaxed text-[var(--text)]">{positioningSummary}</p>
        )}
        {scenarios.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {scenarios.map((s) => (
              <span class="rounded-full bg-[#f3f4f8] px-2.5 py-1 text-xs text-[var(--muted)]">{s}</span>
            ))}
          </div>
        )}
        {sellingPoints.length > 0 && (
          <ul class="mt-4 m-0 list-none space-y-2 p-0">
            {sellingPoints.map((sp) => {
              const tags = collectSellingPointTags(sp);
              return (
                <li class="flex gap-2 rounded-xl border border-[var(--line)] bg-[#fafbff] p-3">
                  <div class="flex shrink-0 flex-wrap gap-1 self-start">
                    {tags.map((t) => {
                      const style = sellingPointTagStyle(t);
                      return (
                        <span
                          class="inline-block rounded-full px-2 py-0.5 text-xs font-semibold"
                          style={`background:${style.bg};color:${style.text}`}
                        >
                          {t}
                        </span>
                      );
                    })}
                  </div>
                  <p class="m-0 flex-1 text-sm leading-relaxed text-[var(--text)]">{sp.text}</p>
                </li>
              );
            })}
          </ul>
        )}
      </section>
    )
  }

  {
    unboxing && (
      <section class="mt-8">
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h2 class="m-0 text-lg font-bold">开箱 · 外观</h2>
          {unboxing.completeness != null && (
            <span class="text-sm text-[var(--muted)]">
              模块完整度 {Math.round((unboxing.completeness || 0) * 100)}%
            </span>
          )}
        </div>
        <div class="mt-4 flex flex-col gap-6">
          {unboxSections.map(({ key, title, mod }) => {
            if (!mod) return null;
            const images = resolveImages(mod.appearance_images);
            const metrics = computeUnboxModuleMetrics(mod, images.length, key);
            const palette = unboxModuleStyle(title);
            const totalImages = Math.max(
              mod.image_count || 0,
              (mod.appearance_images || []).length,
              images.length
            );
            return (
              <section
                class="rounded-2xl border border-[var(--line)] bg-white p-5 shadow-sm"
                style={`border-color:${palette.border}`}
              >
                <div class="flex flex-wrap items-baseline justify-between gap-2">
                  <h3 class="m-0 flex flex-wrap items-center gap-2 text-lg font-bold">
                    <span
                      class="rounded-full px-2.5 py-0.5 text-xs font-semibold"
                      style={`background:${palette.bg};color:${palette.text}`}
                    >
                      {title}
                    </span>
                    <span class="text-sm font-normal text-[var(--muted)]">
                      共 {totalImages} 张 · 已缓存 {images.length} 张 · 完整度 {metrics.overall}%
                    </span>
                  </h3>
                </div>

                <div class="mt-3 grid gap-2 sm:grid-cols-3">
                  {metrics.bars.map((bar) => (
                    <div class="rounded-xl bg-[#fafbff] px-3 py-2">
                      <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-[var(--muted)]">{bar.label}</span>
                        <span class="font-semibold" style={`color:${palette.text}`}>{bar.value}%</span>
                      </div>
                      <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-[#eef1f6]">
                        <div
                          class="h-full rounded-full"
                          style={`width:${bar.value}%;background:${palette.bar}`}
                        />
                      </div>
                      <div class="mt-1 text-[10px] text-[var(--muted)]">{bar.detail}</div>
                    </div>
                  ))}
                </div>

                {mod.description && (
                  <p class="mt-3 text-sm leading-relaxed text-[var(--text)]">{mod.description}</p>
                )}

                {title === "包装" && (mod.accessories || []).length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {(mod.accessories || []).map((acc) => (
                      <span
                        class="rounded-full px-2 py-0.5 text-xs font-medium"
                        style={`background:${palette.bg};color:${palette.text}`}
                      >
                        {acc}
                      </span>
                    ))}
                  </div>
                )}

                {images.length > 0 ? (
                  <div class="mt-4 flex gap-3 overflow-x-auto pb-1">
                    {images.map((img) => {
                      const lbIdx = allLightboxImages.findIndex((x) => x.src === img.src);
                      return (
                        <figure class="m-0 w-56 flex-shrink-0 rounded-2xl border border-[var(--line)] bg-white p-3 shadow-sm">
                          <button
                            type="button"
                            class="block w-full cursor-zoom-in border-0 bg-transparent p-0"
                            data-lightbox-index={lbIdx >= 0 ? lbIdx : 0}
                          >
                            <img
                              src={img.src}
                              alt={img.alt || img.caption || title}
                              class="h-36 w-full rounded-lg border border-[var(--line)] object-cover"
                              loading="lazy"
                            />
                          </button>
                          {img.caption && (
                            <figcaption class="mt-2 line-clamp-3 text-xs leading-snug text-[var(--muted)]">
                              {img.caption}
                            </figcaption>
                          )}
                        </figure>
                      );
                    })}
                  </div>
                ) : (
                  <p class="mt-4 text-sm text-[var(--muted)]">暂无已缓存的外观图</p>
                )}
              </section>
            );
          })}
        </div>
      </section>
    )
  }

  <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    {
      [
        ["主控芯片", snap.main_chip],
        ["PMIC", snap.pmic_case],
        ["耳机电池", snap.battery_ear],
        ["仓电池", snap.battery_case],
        ["喇叭", snap.speaker],
        ["材料", snap.materials],
        ...weightCards,
        ["售价", priceTxt],
      ].map(([label, val]) => (
        <div class="rounded-xl border border-[var(--line)] bg-white p-4">
          <div class="text-xs text-[var(--muted)]">{label}</div>
          <div class="mt-1 font-semibold">{val || "—"}</div>
        </div>
      ))
    }
  </div>

  <h2 class="mt-8 text-lg font-bold">物料清单（BOM）</h2>
  <p class="mb-3 text-xs text-[var(--muted)]">
    「类型」中「核心部件 / 外围部件」表示拆解报告中的部件重要度；芯片行会标注主控、PMIC 等职能。
  </p>
  {caseRows.length > 0 && (
    <>
      <h3 class="text-sm font-semibold text-[var(--muted)]">充电盒</h3>
      <div class="overflow-x-auto rounded-xl border border-[var(--line)] bg-white">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[#f8faff] text-left">
              <th class="px-3 py-2">部件</th>
              <th class="px-3 py-2">厂商</th>
              <th class="px-3 py-2">型号</th>
              <th class="px-3 py-2">类型</th>
            </tr>
          </thead>
          <tbody>
            {caseRows.map((r: { component: string; brand: string; model: string; role: string }) => (
              <tr class="border-t border-[var(--line)]">
                <td class="px-3 py-2">{formatCell(r.component)}</td>
                <td class="px-3 py-2">{formatCell(r.brand)}</td>
                <td class="px-3 py-2">{formatCell(r.model)}</td>
                <td class="px-3 py-2">{formatBomRole(r.role)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}
  {earRows.length > 0 && (
    <>
      <h3 class="mt-4 text-sm font-semibold text-[var(--muted)]">耳机</h3>
      <div class="overflow-x-auto rounded-xl border border-[var(--line)] bg-white">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[#f8faff] text-left">
              <th class="px-3 py-2">部件</th>
              <th class="px-3 py-2">厂商</th>
              <th class="px-3 py-2">型号</th>
              <th class="px-3 py-2">类型</th>
            </tr>
          </thead>
          <tbody>
            {earRows.map((r: { component: string; brand: string; model: string; role: string }) => (
              <tr class="border-t border-[var(--line)]">
                <td class="px-3 py-2">{formatCell(r.component)}</td>
                <td class="px-3 py-2">{formatCell(r.brand)}</td>
                <td class="px-3 py-2">{formatCell(r.model)}</td>
                <td class="px-3 py-2">{formatBomRole(r.role)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}
  {otherRows.length > 0 && (
    <>
      <h3 class="mt-4 text-sm font-semibold text-[var(--muted)]">整机 / 未标注位置</h3>
      <div class="overflow-x-auto rounded-xl border border-[var(--line)] bg-white">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[#f8faff] text-left">
              <th class="px-3 py-2">部件</th>
              <th class="px-3 py-2">厂商</th>
              <th class="px-3 py-2">型号</th>
              <th class="px-3 py-2">类型</th>
            </tr>
          </thead>
          <tbody>
            {otherRows.map((r: { component: string; brand: string; model: string; role: string }) => (
              <tr class="border-t border-[var(--line)]">
                <td class="px-3 py-2">{formatCell(r.component)}</td>
                <td class="px-3 py-2">{formatCell(r.brand)}</td>
                <td class="px-3 py-2">{formatCell(r.model)}</td>
                <td class="px-3 py-2">{formatBomRole(r.role)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}

  {
    resolvedSummaryImages.length > 0 && (
      <>
        <h2 class="mt-8 text-lg font-bold">物料总结图</h2>
        <div class="mt-3 flex flex-wrap gap-3">
          {resolvedSummaryImages.map((img, idx) => (
            <button
              type="button"
              class="cursor-zoom-in border-0 bg-transparent p-0"
              data-lightbox-index={idx}
            >
              <img
                src={img.src}
                alt={img.alt || "物料图"}
                class="max-h-40 rounded-lg border border-[var(--line)]"
                loading="lazy"
              />
            </button>
          ))}
        </div>
      </>
    )
  }

  <div class="mt-8 text-sm">
    <h2 class="text-lg font-bold">关联情报</h2>
    <ul class="list-disc pl-5 text-[var(--muted)]">
      {
        (product.report_ids || []).map((rid: string) => (
          <li>
            <a href={withBase(`/report/${rid}`)}>拆解报告 {rid}</a>
          </li>
        ))
      }
    </ul>
  </div>

  <div
    id="lightbox-overlay"
    class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/85 p-4"
    role="dialog"
    aria-modal="true"
    aria-label="图片预览"
  >
    <button
      type="button"
      id="lightbox-close"
      class="absolute right-4 top-4 rounded-full bg-white/10 px-3 py-1 text-2xl text-white hover:bg-white/20"
      aria-label="关闭"
    >
      ×
    </button>
    <button type="button" id="lightbox-prev" class="absolute left-3 top-1/2 -translate-y-1/2 rounded-full bg-white/10 px-3 py-2 text-white hover:bg-white/20" aria-label="上一张">‹</button>
    <button type="button" id="lightbox-next" class="absolute right-3 top-1/2 -translate-y-1/2 rounded-full bg-white/10 px-3 py-2 text-white hover:bg-white/20" aria-label="下一张">›</button>
    <figure class="max-h-[90vh] max-w-[min(1200px,95vw)]">
      <img id="lightbox-img" src="" alt="" class="max-h-[82vh] w-auto max-w-full rounded-lg object-contain shadow-2xl" />
      <figcaption id="lightbox-caption" class="mt-3 text-center text-sm text-white/85"></figcaption>
    </figure>
  </div>

  <script define:vars={{ lightboxJson }}>
    const images = JSON.parse(lightboxJson);
    const overlay = document.getElementById("lightbox-overlay");
    const imgEl = document.getElementById("lightbox-img");
    const capEl = document.getElementById("lightbox-caption");
    let current = 0;

    function show(idx) {
      if (!images.length || !overlay || !imgEl) return;
      current = (idx + images.length) % images.length;
      const item = images[current];
      imgEl.src = item.src;
      imgEl.alt = item.alt || item.caption || "";
      if (capEl) {
        capEl.textContent = item.caption
          ? `${item.caption} (${current + 1}/${images.length})`
          : images.length > 1
            ? `${current + 1} / ${images.length}`
            : "";
      }
      overlay.classList.remove("hidden");
      overlay.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function hide() {
      if (!overlay) return;
      overlay.classList.add("hidden");
      overlay.classList.remove("flex");
      document.body.style.overflow = "";
    }

    document.querySelectorAll("[data-lightbox-index]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = parseInt(btn.getAttribute("data-lightbox-index") || "0", 10);
        show(idx);
      });
    });

    document.getElementById("lightbox-close")?.addEventListener("click", hide);
    document.getElementById("lightbox-prev")?.addEventListener("click", (e) => {
      e.stopPropagation();
      show(current - 1);
    });
    document.getElementById("lightbox-next")?.addEventListener("click", (e) => {
      e.stopPropagation();
      show(current + 1);
    });
    overlay?.addEventListener("click", (e) => {
      if (e.target === overlay) hide();
    });
    window.addEventListener("keydown", (e) => {
      if (overlay?.classList.contains("hidden")) return;
      if (e.key === "Escape") hide();
      if (e.key === "ArrowLeft") show(current - 1);
      if (e.key === "ArrowRight") show(current + 1);
    });
  </script>
</BaseLayout>
